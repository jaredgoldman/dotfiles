{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git tag:*)",
      "Bash(git remote:*)",
      "Bash(git blame:*)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-files:*)",
      "Bash(git ls-tree:*)",
      "Bash(git ls-remote:*)",
      "Bash(git shortlog:*)",
      "Bash(git describe:*)",
      "Bash(git cat-file:*)",
      "Bash(git mv:*)",
      "Bash(git worktree add:*)",
      "Bash(git stash:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(file:*)",
      "Bash(which:*)",
      "Bash(pwd:*)",
      "Bash(echo:*)",
      "Bash(tree:*)",
      "Bash(stat:*)",
      "Bash(realpath:*)",
      "Bash(dirname:*)",
      "Bash(basename:*)",
      "Bash(env:*)",
      "Bash(printenv:*)",
      "Bash(whoami:*)",
      "Bash(id:*)",
      "Bash(uname:*)",
      "Bash(df:*)",
      "Bash(du:*)",
      "Bash(date:*)",
      "Bash(pnpm -F ingestion build:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm run test:vitest:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm:*)",
      "Bash(npx tsc:*)",
      "Bash(ENV=default TABLE_NAME=test pnpm vitest run:*)",
      "Bash(ENV_NAME=staging ENV=default TABLE_NAME_NO_LSI=test TABLE_NAME=test WAREHOUSE_TABLE=test OPPORTUNITY_TABLE=test TABLE=test AUDIENCE=audience ORGANIZATION=osflabs OSF_OTC_ADMIN_API_URL=test OSF_OTC_ADMIN_API_SECRET=test pnpm vitest run:*)",
      "Bash(node:*)",
      "Bash(ENV=default TABLE_NAME=test AUDIENCE=audience ORGANIZATION=osflabs pnpm --filter @osfmgmt/matcher test:*)",
      "Bash(LOG_LEVEL=debug pnpm start:*)",
      "mcp__claude_ai_Atlassian__*",
      "WebFetch",
      "WebSearch",
      "Bash(TABLE_NAME=test-table ENV_NAME=test pnpm vitest run:*)",
      "Bash(jq:*)",
      "Bash(tsc:*)",
      "Bash(npx -y tsc:*)",
      "Bash(TABLE_NAME=test npx vitest run:*)",
      "Bash(TABLE_NAME=test node:*)",
      "Bash(python3:*)",
      "Bash(xargs:*)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Grep(**/.env)",
      "Grep(**/.env.*)",
      "Bash(cat .env:*)",
      "Bash(head .env:*)",
      "Bash(tail .env:*)",
      "Bash(less .env:*)",
      "Bash(more .env:*)",
      "Bash(source .env:*)"
    ],
    "defaultMode": "default"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true
  }
}
